# ============================================================
# Multimodal RAG System — Environment Configuration Example
# ============================================================
# Copy this file to .env and fill in your values.
# ============================================================

# Embedding
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Retrieval
TOP_K=5

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# LLM Provider — "groq" (default) or "ollama" (local)
# ── GroqCloud (recommended for production) ──
LLM_PROVIDER=groq
LLM_API_BASE=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=gsk_your_groq_api_key_here

# ── Local Ollama (uncomment to use instead) ──
# LLM_PROVIDER=ollama
# LLM_API_BASE=http://localhost:11434/v1
# LLM_MODEL=llama3
# LLM_API_KEY=

# Observability
LOG_LEVEL=INFO
APP_VERSION=0.1.0

# Database
# Local dev: SQLite (no setup needed)
DATABASE_URL=sqlite:///./rag_auth.db
# Production: PostgreSQL
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT — CHANGE THIS in production (use: openssl rand -hex 32)
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Email (Resend API — https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# Google OAuth (https://console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=

# CORS — comma-separated allowed origins for production
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://api.yourdomain.com
