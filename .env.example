# ============================================================
# Multimodal RAG System — Environment Configuration Example
# ============================================================
# Copy this file to .env and adjust values for your environment.
# All values shown here are the application defaults.
# ============================================================

# ------------------------------------
# Embedding configuration
# ------------------------------------
# sentence-transformers model name used for encoding chunks and queries.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ------------------------------------
# Chunking configuration
# ------------------------------------
# Maximum number of characters per chunk.
CHUNK_SIZE=512

# Number of characters of overlap between consecutive chunks.
CHUNK_OVERLAP=64

# ------------------------------------
# Retrieval configuration
# ------------------------------------
# Default number of top results to return for a query.
TOP_K=5

# ------------------------------------
# ChromaDB configuration
# ------------------------------------
# Directory where ChromaDB persists its data on disk.
CHROMA_PERSIST_DIR=./chroma_db

# ------------------------------------
# LLM backend configuration
# ------------------------------------
# Base URL of the OpenAI-compatible API endpoint.
# Default points to a local Ollama instance.
LLM_API_BASE=http://localhost:11434/v1

# Name of the model to use for answer generation.
LLM_MODEL=llama3

# API key for the LLM backend. Use "ollama" for local Ollama instances.
LLM_API_KEY=ollama

# ------------------------------------
# Observability
# ------------------------------------
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ------------------------------------
# Application metadata
# ------------------------------------
APP_VERSION=0.1.0
